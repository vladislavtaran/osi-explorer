# Add inside your HTTPS server { } block.

# static frontend at /osi/  (put web/ contents in the web root under osi/)
# (served by the default `location /` — no extra block needed)

# backend proxy (systemd: osi.service on 127.0.0.1:8091)
location /osi/api/ {
    proxy_pass http://127.0.0.1:8091/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 30s;
    proxy_buffering off;
}
